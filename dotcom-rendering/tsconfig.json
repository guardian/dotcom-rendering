{
	"extends": "@guardian/tsconfig/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"jsxImportSource": "@emotion/react",
		"lib": ["esnext", "es2015", "dom"],
		"moduleResolution": "bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"preserveConstEnums": true,
		"types": [
			"node",
			"jest",
			"react",
			"react-dom",
			"@testing-library/jest-dom",
			"vite/client",
			"youtube",
			"twitter-for-web",
			// This is to fix a "Cannot find namespace 'Chai'" error that arose during
			// the upgrade to Storybook 9. Storybook uses vitest, which has chai as a
			// dependency, and this makes the chai types available globally.
			"chai"
		]
	},
	"exclude": [
		"storybook-static",
		"target",
		"dist",
		"node_modules",
		"playwright-report"
	]
}
