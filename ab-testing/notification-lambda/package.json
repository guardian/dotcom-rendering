{
	"name": "@guardian/ab-testing-notification-lambda",
	"version": "1.0.0",
	"description": "Scheduled Lambda that checks expiry dates for active AB tests and notifies if close to expiry or has expired",
	"main": "index.ts",
	"type": "module",
	"scripts": {
		"dev": "node src/run.ts",
		"build": "rollup -c rollup.config.js",
		"test": "node --test --experimental-test-module-mocks --test-reporter spec './**/*.test.ts'"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "3.995.0",
		"@aws-sdk/credential-providers": "3.995.0",
		"@guardian/ab-testing-config": "workspace:ab-testing-config"
	},
	"devDependencies": {
		"@guardian/tsconfig": "catalog:",
		"@rollup/plugin-commonjs": "catalog:",
		"@rollup/plugin-json": "catalog:",
		"@rollup/plugin-node-resolve": "catalog:",
		"@types/aws-lambda": "catalog:",
		"@types/node": "catalog:",
		"esbuild": "catalog:",
		"rollup": "catalog:",
		"rollup-plugin-esbuild": "catalog:",
		"type-fest": "catalog:",
		"typescript": "catalog:"
	}
}
