{
	"name": "@guardian/ab-testing-deploy-lambda",
	"version": "1.0.0",
	"description": "Lambda that deploys AB test configuration to Fastly edge-dictionaries",
	"main": "index.ts",
	"type": "module",
	"scripts": {
		"build": "rollup -c rollup.config.js",
		"test": "node --test --experimental-test-module-mocks --test-reporter spec './**/*.test.ts'"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:",
		"@aws-sdk/client-ssm": "catalog:",
		"@guardian/ab-testing-config": "workspace:ab-testing-config",
		"superstruct": "catalog:"
	},
	"devDependencies": {
		"@guardian/tsconfig": "catalog:",
		"@rollup/plugin-commonjs": "catalog:",
		"@rollup/plugin-json": "catalog:",
		"@rollup/plugin-node-resolve": "catalog:",
		"@types/aws-lambda": "catalog:",
		"@types/node": "catalog:",
		"esbuild": "catalog:",
		"rollup": "catalog:",
		"rollup-plugin-esbuild": "catalog:",
		"type-fest": "catalog:",
		"typescript": "catalog:"
	}
}
