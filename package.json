{
	"name": "dotcom-rendering",
	"version": "1.0.0",
	"repository": "git@github.com:guardian/dotcom-rendering.git",
	"license": "Apache-2.0",
	"private": true,
	"scripts": {
		"postinstall": "./scripts/postinstall.sh",
		"build:dcr": "cd dotcom-rendering && make build",
		"chromatic": "chromatic --build-script-name=build-storybook --exit-zero-on-changes",
		"prepare": "husky",
		"lint-staged": "lint-staged",
		"prettier:check": "prettier --ignore-unknown --check --cache .",
		"prettier:write": "prettier --ignore-unknown --write --cache ."
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"ab-testing/**/*": "pnpm --filter @guardian/ab-testing-* lint-staged"
	},
	"dependencies": {
		"@guardian/cdk": "62.6.1",
		"@guardian/prettier": "5.0.0",
		"@types/chai": "5.2.2",
		"aws-cdk": "2.1110.0",
		"aws-cdk-lib": "2.241.0",
		"chromatic": "13.3.4",
		"constructs": "10.5.1",
		"husky": "9.1.7",
		"lint-staged": "15.2.0",
		"prettier": "3.0.3",
		"tslib": "2.6.2"
	},
	"packageManager": "pnpm@9.15.9"
}
